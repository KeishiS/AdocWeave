      "archive": "tar.xz",
      "executable": "adocweave"
    },
    {
      "name": "adocweave-cli-x86_64-unknown-linux-musl.tar.xz",
      "kind": "cli",
      "target": "x86_64-unknown-linux-musl",
      "archive": "tar.xz",
      "executable": "adocweave"
    },
    {
      "name": "adocweave-lsp-aarch64-unknown-linux-musl.tar.xz",
      "kind": "lsp",
      "target": "aarch64-unknown-linux-musl",
      "archive": "tar.xz",
      "executable": "adocweave-lsp"
    },
    {
      "name": "adocweave-lsp-x86_64-unknown-linux-musl.tar.xz",
      "kind": "lsp",
      "target": "x86_64-unknown-linux-musl",
      "archive": "tar.xz",
      "executable": "adocweave-lsp"
    },
    {
      "name": "adocweave-browser-0.1.0-rc.3.tar.xz",
      "kind": "browser",
      "target": null,
      "archive": "tar.xz",
      "executable": null
    },
    {
      "name": "adocweave-zed-0.1.0-rc.3.tar.xz",
      "kind": "zed",
      "target": null,
      "archive": "tar.xz",
      "executable": null
    }
  ],
  "releaseMetadata": [
    {
      "name": "adocweave-dist-manifest.json",
      "kind": "distribution-manifest",
      "format": "canonical-json"
    },
    {
      "name": "adocweave.spdx.json",
      "kind": "sbom",
      "format": "spdx-json"
    },
    {
      "name": "sha256.sum",
      "kind": "checksums",
      "format": "sha256"
    }
  ]
