{
  "schemaVersion": 1,
  "packageVersion": "0.1.0-rc.3",
  "distVersion": "0.32.0",
  "repository": "https://github.com/KeishiS/AdocWeave",
  "targets": [
    "aarch64-unknown-linux-musl",
    "x86_64-unknown-linux-musl"
